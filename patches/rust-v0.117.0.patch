diff --git a/codex-rs/core/src/auto_compact_reset.rs b/codex-rs/core/src/auto_compact_reset.rs
new file mode 100644
index 0000000..98455d2
--- /dev/null
+++ b/codex-rs/core/src/auto_compact_reset.rs
@@ -0,0 +1,374 @@
+use std::fs;
+use std::path::{Path, PathBuf};
+use std::sync::Arc;
+
+use crate::codex::{Session, TurnContext};
+use crate::compact::InitialContextInjection;
+use crate::config::Config;
+use crate::error::Result as CodexResult;
+use crate::Prompt;
+use crate::client_common::ResponseEvent;
+use codex_protocol::items::{ContextCompactionItem, TurnItem};
+use codex_protocol::models::ResponseInputItem;
+use crate::protocol::CompactedItem;
+use codex_protocol::models::{ContentItem, ResponseItem};
+use futures::prelude::*;
+use chrono::Utc;
+use codex_protocol::ThreadId;
+use tracing::warn;
+
+const RESET_CATCH_UP_NOTE_NAME: &str = "catch-up.md";
+const RESET_RECENT_SNIPPET_LIMIT: usize = 3;
+
+const DISTILLATION_PROMPT: &str = r#"
+You are a background cognitive organizer. Your task is to distill the following raw conversation log into a structured, semantic knowledge graph. 
+
+Ignore all previous summaries or meta-commentary. Focus only on the actual events, code changes, tool outputs, and decisions made.
+
+Output your analysis in TWO sections, formatted exactly as follows, using Obsidian Markdown syntax:
+
+# Themes
+(Extract core architectural decisions, persistent state, and recurring technical patterns. Create links like [[themes/database_schema]] where appropriate.)
+- ...
+
+# Timeline
+(Identify the chronological sequence of key milestones, bugs fixed, and task transitions.)
+- ...
+"#;
+
+fn obsidian_graph_root(config: &Config) -> &Path {
+    &config.experimental_obsidian_graph_root
+}
+
+pub(crate) fn thread_graph_root(config: &Config, thread_id: &ThreadId) -> PathBuf {
+    obsidian_graph_root(config).join(thread_id.to_string())
+}
+
+pub(crate) fn graph_continuity_instruction(config: &Config, thread_id: &ThreadId) -> String {
+    let thread_root = thread_graph_root(config, thread_id);
+    let catch_up_path = thread_root.join(RESET_CATCH_UP_NOTE_NAME);
+    let index_path = thread_root.join("index.md");
+    let continuity_start = if catch_up_path.exists() {
+        format!(
+            "Start with `{}` for the latest handoff, then use `{}` as the thread map.",
+            catch_up_path.display(),
+            index_path.display(),
+        )
+    } else {
+        format!(
+            "Start with `{}`, then consult `timeline/`, `themes/`, and the newest `segments/` entries.",
+            index_path.display(),
+        )
+    };
+    format!(
+        "Continuity mode is reset-based, not summary-based. If older thread continuity matters, prefer the filesystem graph at `{}`. {}",
+        thread_root.display(),
+        continuity_start,
+    )
+}
+
+async fn distill_history_to_graph(
+    sess: &Session,
+    turn_context: &TurnContext,
+    history_items: &[ResponseItem],
+) -> CodexResult<String> {
+    let mut client_session = sess.services.model_client.new_session();
+    let turn_metadata_header = turn_context.turn_metadata_state.current_header_value();
+
+    let mut raw_log_text = String::new();
+    for item in history_items {
+        if let ResponseItem::Message { role, content, .. } = item {
+            if role != "system" {
+                for c in content {
+                    if let ContentItem::InputText { text } = c {
+                        raw_log_text.push_str(&format!("[{}]: {}\n\n", role, text));
+                    }
+                }
+            }
+        }
+    }
+
+    let full_prompt_text = format!("{}\n\nRAW LOG:\n{}", DISTILLATION_PROMPT, raw_log_text);
+
+    let input_item = ResponseInputItem::Message {
+        role: "user".to_string(),
+        content: vec![codex_protocol::models::ContentItem::InputText { text: full_prompt_text }],
+    };
+
+    let prompt = Prompt {
+        input: vec![input_item.into()],
+        base_instructions: codex_protocol::models::BaseInstructions::default(),
+        personality: None,
+        ..Default::default()
+    };
+
+    let mut stream = client_session
+        .stream(
+            &prompt,
+            &turn_context.model_info,
+            &turn_context.session_telemetry,
+            turn_context.reasoning_effort.clone(),
+            turn_context.reasoning_summary,
+            turn_context.config.service_tier,
+            turn_metadata_header.as_deref(),
+        )
+        .await?;
+
+    let mut distilled_output = String::new();
+
+    loop {
+        let maybe_event = stream.next().await;
+        let Some(event) = maybe_event else { break; };
+        
+        match event {
+            Ok(ResponseEvent::OutputTextDelta(delta)) => {
+                distilled_output.push_str(&delta);
+            }
+            Ok(ResponseEvent::Completed { .. }) => { break; }
+            Err(e) => {
+                warn!("Stream error during distillation: {:?}", e);
+                break;
+            }
+            _ => {}
+        }
+    }
+
+    Ok(distilled_output)
+}
+
+fn parse_and_write_graph(
+    thread_root: &Path,
+    distilled_text: &str,
+) -> std::io::Result<()> {
+    let themes_dir = thread_root.join("themes");
+    let timeline_dir = thread_root.join("timeline");
+    fs::create_dir_all(&themes_dir)?;
+    fs::create_dir_all(&timeline_dir)?;
+
+    let mut in_themes = false;
+    let mut in_timeline = false;
+    let mut themes_content = String::new();
+    let mut timeline_content = String::new();
+
+    for line in distilled_text.lines() {
+        if line.starts_with("# Themes") {
+            in_themes = true;
+            in_timeline = false;
+            continue;
+        } else if line.starts_with("# Timeline") {
+            in_themes = false;
+            in_timeline = true;
+            continue;
+        }
+
+        if in_themes {
+            themes_content.push_str(line);
+            themes_content.push('\n');
+        } else if in_timeline {
+            timeline_content.push_str(line);
+            timeline_content.push('\n');
+        }
+    }
+
+    if !themes_content.trim().is_empty() {
+        fs::write(themes_dir.join("index.md"), themes_content)?;
+    }
+    if !timeline_content.trim().is_empty() {
+        fs::write(timeline_dir.join("overview.md"), timeline_content)?;
+    }
+
+    Ok(())
+}
+
+pub(crate) async fn run_auto_reset_compact(
+    sess: Arc<Session>,
+    turn_context: Arc<TurnContext>,
+    initial_context_injection: InitialContextInjection,
+) -> CodexResult<()> {
+    let compaction_item = ContextCompactionItem::new();
+    sess.emit_turn_item_started(&turn_context, &TurnItem::ContextCompaction(compaction_item.clone())).await;
+
+    // Phase 1: Rumination (Distill Meaning)
+    sess.notify_background_event(&turn_context, "Ruminating on knowledge graph evolution...".to_string()).await;
+    
+    let history_snapshot = sess.clone_history().await;
+    let history_items = history_snapshot.raw_items();
+    let thread_root = thread_graph_root(&turn_context.config, &sess.conversation_id);
+
+    // The Distillation Engine (Semantic Handoff)
+    if let Ok(distilled_text) = distill_history_to_graph(sess.as_ref(), turn_context.as_ref(), history_items).await {
+        if let Err(e) = parse_and_write_graph(&thread_root, &distilled_text) {
+             warn!("Failed to write distilled graph: {:?}", e);
+        }
+    } else {
+        warn!("Distillation pass failed.");
+    }
+    
+    let exported_segment_root = export_graph_segment(
+        &thread_root,
+        &sess.conversation_id,
+        &turn_context.sub_id,
+        initial_context_injection,
+        history_items,
+    ).ok();
+
+    let reset_map_capsule = build_reset_map_capsule(&turn_context.config, &sess.conversation_id, exported_segment_root.as_deref());
+
+    let (new_history, reference_context_item): (Vec<ResponseItem>, Option<codex_protocol::protocol::TurnContextItem>) = build_reset_replacement_history(
+        sess.as_ref(),
+        turn_context.as_ref(),
+        initial_context_injection,
+        reset_map_capsule,
+    )
+    .await;
+
+    let compacted_item = CompactedItem {
+        message: format!("Context reset. Meaning graph updated at {}", thread_root.display()),
+        replacement_history: Some(new_history.clone()),
+    };
+
+    sess.replace_compacted_history(new_history, reference_context_item, compacted_item).await;
+    sess.recompute_token_usage(&turn_context).await;
+    sess.emit_turn_item_completed(&turn_context, TurnItem::ContextCompaction(compaction_item)).await;
+    
+    Ok(())
+}
+
+async fn build_reset_replacement_history(
+    sess: &Session,
+    turn_context: &TurnContext,
+    initial_context_injection: InitialContextInjection,
+    reset_map_capsule: ResponseItem,
+) -> (Vec<ResponseItem>, Option<codex_protocol::protocol::TurnContextItem>) {
+    let history_snapshot = sess.clone_history().await;
+    let history_items = history_snapshot.raw_items();
+    let mut recent_user_message = None;
+    for item in history_items.iter().rev() {
+        if let ResponseItem::Message { role, .. } = item {
+            if role == "user" {
+                recent_user_message = Some(item.clone());
+                break;
+            }
+        }
+    }
+
+    match initial_context_injection {
+        InitialContextInjection::DoNotInject => {
+            let mut history = vec![reset_map_capsule];
+            if let Some(msg) = recent_user_message {
+                history.push(msg);
+            }
+            (history, None)
+        }
+        InitialContextInjection::BeforeLastUserMessage => {
+            let mut initial_context = sess.build_initial_context(turn_context).await;
+            initial_context.push(reset_map_capsule);
+            if let Some(msg) = recent_user_message {
+                initial_context.push(msg);
+            }
+            (initial_context, Some(turn_context.to_turn_context_item()))
+        }
+    }
+}
+
+fn build_reset_map_capsule(config: &Config, thread_id: &ThreadId, _segment_root: Option<&Path>) -> ResponseItem {
+    let content = graph_continuity_instruction(config, thread_id);
+    ResponseItem::Message {
+        id: None,
+        role: "system".to_string(),
+        content: vec![ContentItem::InputText { text: format!("Reset map capsule. {}", content) }],
+        phase: None,
+        end_turn: None,
+    }
+}
+
+fn export_graph_segment(
+    thread_root: &Path,
+    thread_id: &ThreadId,
+    turn_id: &str,
+    _initial_context_injection: InitialContextInjection,
+    history_items: &[ResponseItem],
+) -> std::io::Result<PathBuf> {
+    let timestamp = Utc::now();
+    let segment_id = format!("{}-{}", timestamp.format("%Y%m%dT%H%M%SZ"), turn_id);
+    let segment_root = thread_root.join("segments").join(&segment_id);
+    fs::create_dir_all(&segment_root)?;
+
+    let messages_root = segment_root.join("messages");
+    fs::create_dir_all(&messages_root)?;
+
+    fs::write(
+        segment_root.join("history.json"),
+        serde_json::to_vec_pretty(history_items).map_err(|e| std::io::Error::new(std::io::ErrorKind::Other, e))?,
+    )?;
+
+    write_reset_catch_up_note(thread_root, thread_id, &segment_root, history_items)?;
+    write_thread_index(thread_root, thread_id)?;
+    Ok(segment_root)
+}
+
+fn write_reset_catch_up_note(
+    thread_root: &Path,
+    thread_id: &ThreadId,
+    _segment_root: &Path,
+    history_items: &[ResponseItem],
+) -> std::io::Result<()> {
+    let catch_up_path = thread_root.join(RESET_CATCH_UP_NOTE_NAME);
+    let index_path = thread_root.join("index.md");
+    let recent_user_messages: Vec<String> = history_items.iter().rev().filter_map(|item| {
+        if let ResponseItem::Message { role, content, .. } = item {
+            if role == "user" {
+                let text = content.iter().filter_map(|c| if let ContentItem::InputText{text} = c { Some(text.as_str()) } else { None }).collect::<Vec<_>>().join("\n");
+                Some(format!("- Latest user ask: {}", text))
+            } else { None }
+        } else { None }
+    }).take(RESET_RECENT_SNIPPET_LIMIT).collect();
+
+    let mut body = format!(
+        r#"# Reset Catch-Up
+
+- Thread: `{}`
+- Read this note first, then open `{}` for the full thread map.
+
+## Recent Direction
+"#,
+        thread_id,
+        index_path.display(),
+    );
+    if recent_user_messages.is_empty() {
+        body.push_str("- No recent user messages found.\n");
+    } else {
+        body.push_str(&recent_user_messages.join("\n"));
+    }
+
+    fs::write(catch_up_path, body)
+}
+
+fn write_thread_index(thread_root: &Path, thread_id: &ThreadId) -> std::io::Result<()> {
+    let segments_root = thread_root.join("segments");
+    let mut segment_names = if segments_root.exists() {
+        fs::read_dir(&segments_root)?
+            .filter_map(Result::ok)
+            .filter_map(|entry| {
+                entry.file_type().ok().filter(|ft| ft.is_dir()).map(|_| entry.file_name().to_string_lossy().into_owned())
+            })
+            .collect::<Vec<_>>()
+    } else {
+        Vec::new()
+    };
+    segment_names.sort();
+    segment_names.reverse();
+
+    let mut body = format!(r#"# Thread {}
+
+## Segments
+"#, thread_id);
+    if segment_names.is_empty() {
+        body.push_str("- No segments exported yet.\n");
+    } else {
+        for name in segment_names {
+            body.push_str(&format!("- [[segments/{}/segment|{}]]\n", name, name));
+        }
+    }
+    fs::write(thread_root.join("index.md"), body)
+}
