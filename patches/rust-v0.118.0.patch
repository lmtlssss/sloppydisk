diff --git a/codex-rs/core/src/auto_compact_reset.rs b/codex-rs/core/src/auto_compact_reset.rs
new file mode 100644
index 0000000..942226f
--- /dev/null
+++ b/codex-rs/core/src/auto_compact_reset.rs
@@ -0,0 +1,409 @@
+use std::collections::HashSet;
+use std::fs;
+use std::path::{Path, PathBuf};
+use std::sync::Arc;
+
+use chrono::Utc;
+use codex_protocol::ThreadId;
+use codex_protocol::items::{ContextCompactionItem, TurnItem};
+use codex_protocol::models::{ContentItem, ResponseItem};
+
+use crate::codex::{Session, TurnContext};
+use crate::compact::InitialContextInjection;
+use crate::error::Result as CodexResult;
+use crate::protocol::CompactedItem;
+
+const CONTINUITY_DIR_NAME: &str = "sloppydisk";
+const THREADS_DIR_NAME: &str = "threads";
+const CATCH_UP_FILE_NAME: &str = "catch-up.md";
+const CONTRACT_FILE_NAME: &str = "contract.md";
+const SEGMENTS_DIR_NAME: &str = "segments";
+const SEGMENT_HISTORY_FILE_NAME: &str = "history.json";
+const RECENT_USER_MESSAGE_LIMIT: usize = 4;
+const DIRECTIVE_MESSAGE_LIMIT: usize = 8;
+const DIRECTIVE_SCAN_LIMIT: usize = 24;
+
+pub(crate) async fn run_auto_reset_compact(
+    sess: Arc<Session>,
+    turn_context: Arc<TurnContext>,
+    initial_context_injection: InitialContextInjection,
+) -> CodexResult<()> {
+    let compaction_item = ContextCompactionItem::new();
+    sess.emit_turn_item_started(
+        &turn_context,
+        &TurnItem::ContextCompaction(compaction_item.clone()),
+    )
+    .await;
+
+    let history_snapshot = sess.clone_history().await;
+    let history_items = history_snapshot.raw_items();
+    let thread_root = thread_root(turn_context.as_ref(), &sess.conversation_id);
+    export_thread_memory(
+        &thread_root,
+        continuity_root(turn_context.as_ref()).as_path(),
+        &sess.conversation_id,
+        &turn_context.sub_id,
+        history_items,
+    )
+    .ok();
+
+    let reset_map_capsule = build_reset_map_capsule(&thread_root);
+    let (mut new_history, reference_context_item) = build_reset_replacement_history(
+        sess.as_ref(),
+        turn_context.as_ref(),
+        initial_context_injection,
+        reset_map_capsule,
+    )
+    .await;
+    append_ghost_snapshots(&mut new_history, history_items);
+
+    let compacted_item = CompactedItem {
+        message: format!(
+            "Context reset. Continuity updated at {}",
+            thread_root.display()
+        ),
+        replacement_history: Some(new_history.clone()),
+    };
+
+    sess.replace_compacted_history(new_history, reference_context_item, compacted_item)
+        .await;
+    sess.recompute_token_usage(&turn_context).await;
+    sess.emit_turn_item_completed(&turn_context, TurnItem::ContextCompaction(compaction_item))
+        .await;
+
+    Ok(())
+}
+
+fn continuity_root(turn_context: &TurnContext) -> PathBuf {
+    turn_context.config.codex_home.join(CONTINUITY_DIR_NAME)
+}
+
+fn thread_root(turn_context: &TurnContext, thread_id: &ThreadId) -> PathBuf {
+    continuity_root(turn_context)
+        .join(THREADS_DIR_NAME)
+        .join(thread_id.to_string())
+}
+
+async fn build_reset_replacement_history(
+    sess: &Session,
+    turn_context: &TurnContext,
+    initial_context_injection: InitialContextInjection,
+    reset_map_capsule: ResponseItem,
+) -> (
+    Vec<ResponseItem>,
+    Option<codex_protocol::protocol::TurnContextItem>,
+) {
+    let history_snapshot = sess.clone_history().await;
+    let history_items = history_snapshot.raw_items();
+    let recent_user_message = history_items.iter().rev().find_map(|item| match item {
+        ResponseItem::Message { role, .. } if role == "user" => Some(item.clone()),
+        _ => None,
+    });
+
+    match initial_context_injection {
+        InitialContextInjection::DoNotInject => {
+            let mut history = vec![reset_map_capsule];
+            if let Some(msg) = recent_user_message {
+                history.push(msg);
+            }
+            (history, None)
+        }
+        InitialContextInjection::BeforeLastUserMessage => {
+            let mut history = sess.build_initial_context(turn_context).await;
+            history.push(reset_map_capsule);
+            if let Some(msg) = recent_user_message {
+                history.push(msg);
+            }
+            (history, Some(turn_context.to_turn_context_item()))
+        }
+    }
+}
+
+fn append_ghost_snapshots(history: &mut Vec<ResponseItem>, history_items: &[ResponseItem]) {
+    history.extend(
+        history_items
+            .iter()
+            .filter(|item| matches!(item, ResponseItem::GhostSnapshot { .. }))
+            .cloned(),
+    );
+}
+
+fn build_reset_map_capsule(thread_root: &Path) -> ResponseItem {
+    let catch_up_path = thread_root.join(CATCH_UP_FILE_NAME);
+    let contract_path = thread_root.join(CONTRACT_FILE_NAME);
+    let segments_path = thread_root.join(SEGMENTS_DIR_NAME);
+    let content = format!(
+        "Context reset without summary reinjection. Preserve the latest user message as the current steer. If older thread context matters, read `{}` first, then `{}`. Use `{}` only when deeper raw chronology is required. Treat quoted user directives as source of truth over inferred summaries.",
+        catch_up_path.display(),
+        contract_path.display(),
+        segments_path.display(),
+    );
+
+    ResponseItem::Message {
+        id: None,
+        role: "system".to_string(),
+        content: vec![ContentItem::InputText { text: content }],
+        phase: None,
+        end_turn: None,
+    }
+}
+
+fn export_thread_memory(
+    thread_root: &Path,
+    continuity_root: &Path,
+    thread_id: &ThreadId,
+    turn_id: &str,
+    history_items: &[ResponseItem],
+) -> std::io::Result<PathBuf> {
+    let timestamp = Utc::now();
+    let segment_id = format!("{}-{}", timestamp.format("%Y%m%dT%H%M%SZ"), turn_id);
+    let segment_root = thread_root.join(SEGMENTS_DIR_NAME).join(&segment_id);
+    fs::create_dir_all(&segment_root)?;
+    fs::write(
+        segment_root.join(SEGMENT_HISTORY_FILE_NAME),
+        serde_json::to_vec_pretty(history_items).map_err(std::io::Error::other)?,
+    )?;
+
+    write_reset_catch_up_note(thread_root, thread_id, history_items)?;
+    write_contract_note(thread_root, history_items)?;
+    write_thread_index(thread_root, thread_id)?;
+    write_machine_index(continuity_root)?;
+    Ok(segment_root)
+}
+
+fn write_reset_catch_up_note(
+    thread_root: &Path,
+    thread_id: &ThreadId,
+    history_items: &[ResponseItem],
+) -> std::io::Result<()> {
+    let catch_up_path = thread_root.join(CATCH_UP_FILE_NAME);
+    let contract_path = thread_root.join(CONTRACT_FILE_NAME);
+    let recent_messages = recent_user_messages(history_items, RECENT_USER_MESSAGE_LIMIT);
+    let latest_user_message = recent_messages
+        .first()
+        .cloned()
+        .unwrap_or_else(|| "No recent user message found.".to_string());
+
+    let mut body = format!(
+        "# Reset Catch-Up\n\n- Thread: `{}`\n- Read this file first after a reset.\n- Then read `{}` for exact recent directives.\n\n## Live Ask\n\n{}\n\n## Recent User Messages\n\n",
+        thread_id,
+        contract_path.display(),
+        quote_markdown(&latest_user_message),
+    );
+
+    if recent_messages.is_empty() {
+        body.push_str("- No recent user messages found.\n");
+    } else {
+        for message in recent_messages {
+            body.push_str(&quote_markdown(&message));
+            body.push('\n');
+        }
+    }
+
+    fs::write(catch_up_path, body)
+}
+
+fn write_contract_note(thread_root: &Path, history_items: &[ResponseItem]) -> std::io::Result<()> {
+    let contract_path = thread_root.join(CONTRACT_FILE_NAME);
+    let directives = recent_directive_messages(history_items);
+
+    let mut body = String::from(
+        "# Contract\n\nExact recent user messages that look like hard constraints, corrections, or anti-goals. Treat them as the protected contract before inferring anything broader.\n\n",
+    );
+
+    if directives.is_empty() {
+        body.push_str("- No directive-style user messages detected in the recent scan window.\n");
+    } else {
+        for directive in directives {
+            body.push_str(&quote_markdown(&directive));
+            body.push('\n');
+        }
+    }
+
+    fs::write(contract_path, body)
+}
+
+fn write_thread_index(thread_root: &Path, thread_id: &ThreadId) -> std::io::Result<()> {
+    let segments_root = thread_root.join(SEGMENTS_DIR_NAME);
+    let mut segment_names = if segments_root.exists() {
+        fs::read_dir(&segments_root)?
+            .filter_map(Result::ok)
+            .filter_map(|entry| {
+                entry
+                    .file_type()
+                    .ok()
+                    .filter(|ft| ft.is_dir())
+                    .map(|_| entry.file_name().to_string_lossy().into_owned())
+            })
+            .collect::<Vec<_>>()
+    } else {
+        Vec::new()
+    };
+    segment_names.sort();
+    segment_names.reverse();
+
+    let mut body = format!(
+        "# Thread {}\n\n- Catch-up: [[{}]]\n- Contract: [[{}]]\n\n## Raw Segments\n",
+        thread_id, CATCH_UP_FILE_NAME, CONTRACT_FILE_NAME
+    );
+
+    if segment_names.is_empty() {
+        body.push_str("- No raw segments exported yet.\n");
+    } else {
+        for name in segment_names {
+            body.push_str(&format!(
+                "- `segments/{}/{}`\n",
+                name, SEGMENT_HISTORY_FILE_NAME
+            ));
+        }
+    }
+
+    fs::write(thread_root.join("index.md"), body)
+}
+
+fn write_machine_index(continuity_root: &Path) -> std::io::Result<()> {
+    let threads_root = continuity_root.join(THREADS_DIR_NAME);
+    fs::create_dir_all(&threads_root)?;
+
+    let mut thread_names = fs::read_dir(&threads_root)?
+        .filter_map(Result::ok)
+        .filter_map(|entry| {
+            entry
+                .file_type()
+                .ok()
+                .filter(|ft| ft.is_dir())
+                .map(|_| entry.file_name().to_string_lossy().into_owned())
+        })
+        .collect::<Vec<_>>();
+    thread_names.sort();
+    thread_names.reverse();
+
+    let mut body = String::from("# Continuity Index\n\n");
+    if thread_names.is_empty() {
+        body.push_str("- No threads exported yet.\n");
+    } else {
+        for name in thread_names {
+            body.push_str(&format!("- [[threads/{}/index|{}]]\n", name, name));
+        }
+    }
+
+    fs::write(continuity_root.join("index.md"), body)
+}
+
+fn recent_user_messages(history_items: &[ResponseItem], limit: usize) -> Vec<String> {
+    history_items
+        .iter()
+        .rev()
+        .filter_map(user_message_text)
+        .filter(|text| !text.trim().is_empty())
+        .take(limit)
+        .collect()
+}
+
+fn recent_directive_messages(history_items: &[ResponseItem]) -> Vec<String> {
+    let mut directives = Vec::new();
+    let mut seen = HashSet::new();
+
+    for text in history_items
+        .iter()
+        .rev()
+        .filter_map(user_message_text)
+        .filter(|text| !text.trim().is_empty())
+        .take(DIRECTIVE_SCAN_LIMIT)
+    {
+        let normalized = text.trim();
+        if !looks_like_directive(normalized) {
+            continue;
+        }
+        if seen.insert(normalized.to_string()) {
+            directives.push(normalized.to_string());
+        }
+        if directives.len() >= DIRECTIVE_MESSAGE_LIMIT {
+            break;
+        }
+    }
+
+    directives
+}
+
+fn user_message_text(item: &ResponseItem) -> Option<String> {
+    match item {
+        ResponseItem::Message { role, content, .. } if role == "user" => {
+            message_content_text(content)
+        }
+        _ => None,
+    }
+}
+
+fn message_content_text(content: &[ContentItem]) -> Option<String> {
+    let text = content
+        .iter()
+        .filter_map(|item| match item {
+            ContentItem::InputText { text } => Some(text.as_str()),
+            ContentItem::OutputText { text } => Some(text.as_str()),
+            ContentItem::InputImage { .. } => None,
+        })
+        .collect::<Vec<_>>()
+        .join("\n")
+        .trim()
+        .to_string();
+
+    if text.is_empty() { None } else { Some(text) }
+}
+
+fn looks_like_directive(text: &str) -> bool {
+    let lower = text.to_ascii_lowercase();
+    let markers = [
+        "do not",
+        "don't",
+        "must",
+        "mustn't",
+        "never",
+        "only",
+        "exact",
+        "exactly",
+        "preserve",
+        "keep ",
+        "critical",
+        "important",
+        "same",
+        "without",
+        "no ",
+        "wrong",
+        "stop ",
+    ];
+
+    markers.iter().any(|marker| lower.contains(marker))
+}
+
+fn quote_markdown(text: &str) -> String {
+    let mut quoted = String::new();
+    for line in text.lines() {
+        quoted.push_str("> ");
+        quoted.push_str(line);
+        quoted.push('\n');
+    }
+    quoted
+}
+
+#[cfg(test)]
+mod tests {
+    use super::looks_like_directive;
+    use super::quote_markdown;
+
+    #[test]
+    fn directive_detection_finds_constraints() {
+        assert!(looks_like_directive(
+            "do not summarize this and preserve the exact user directive"
+        ));
+        assert!(looks_like_directive(
+            "keep the geometry exact, everything else the same"
+        ));
+        assert!(!looks_like_directive("thanks, looks good"));
+    }
+
+    #[test]
+    fn quote_markdown_preserves_multiline_blocks() {
+        assert_eq!(quote_markdown("one\ntwo"), "> one\n> two\n");
+    }
+}
