{
  "name": "sloppydisk",
  "version": "0.2.0",
  "description": "Minimal contract-preserving reset patcher for OpenAI Codex.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "sloppydisk": "bin/sloppydisk.js"
  },
  "files": [
    "bin",
    "lib",
    "artifacts",
    "patches"
  ],
  "scripts": {
    "patch": "node bin/sloppydisk.js patch",
    "status": "node bin/sloppydisk.js status",
    "stock": "node bin/sloppydisk.js stock",
    "postinstall": "node bin/sloppydisk.js patch --lifecycle",
    "preuninstall": "node bin/sloppydisk.js stock --lifecycle",
    "build-release-artifact": "node scripts/build-release-artifact.cjs",
    "smoke-packaged-install": "node scripts/smoke-packaged-install.cjs"
  },
  "keywords": [
    "codex",
    "openai",
    "patcher",
    "obsidian",
    "continuity"
  ],
  "engines": {
    "node": ">=18"
  }
}
